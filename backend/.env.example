# ============================================================
# POLITECH - Variables de Entorno
# Copia este archivo como .env y rellena los valores reales.
# NUNCA subas tu archivo .env al repositorio.
# ============================================================

# --- Base de Datos ---
# URI de conexión a MongoDB (local o en la nube)
MONGO_URI=mongodb://localhost:27017/politech

# --- IA (Google Gemini) ---
# API Key de Google AI Studio: https://aistudio.google.com/
GEMINI_API_KEY=

# --- Scraping (NewsAPI) ---
# API Key de NewsAPI: https://newsapi.org/
NEWS_API_KEY=

# --- Servidor ---
# Puerto en que corre el backend (por defecto 3000)
PORT=3000

# --- Entorno ---
# Opciones: development | production | test
NODE_ENV=development
